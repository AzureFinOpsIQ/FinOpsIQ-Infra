# Local Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan
*.plan

# Crash logs
crash.log
crash.*.log

# Terraform CLI override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local-only variable files
*.tfvars.local
*.tfvars.json.local

# Terraform lock info from state operations
.terraform.tfstate.lock.info

# Generated bootstrap/report artifacts
bootstrap/bootstrap-outputs.json
*.log
*.tmp
*.cache

# Local validation sandboxes
.tmp-*/
